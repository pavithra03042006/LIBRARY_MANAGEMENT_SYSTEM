<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://jakarta.ee/xml/ns/jakartaee
                             http://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <display-name>Exam Registration System</display-name>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <!-- Student Registration Servlet -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>RegisterServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/RegisterServlet</url-pattern>
    </servlet-mapping>

    <!-- Student Login Servlet -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>servlets.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <!-- Exam Registration Servlet -->
    <servlet>
        <servlet-name>RegisterExamServlet</servlet-name>
        <servlet-class>servlets.RegisterExamServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RegisterExamServlet</servlet-name>
        <url-pattern>/RegisterExamServlet</url-pattern>
    </servlet-mapping>

    <!-- Admin Add Exam Servlet -->
    <servlet>
        <servlet-name>AdminAddExamServlet</servlet-name>
        <servlet-class>servlets.AdminAddExamServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AdminAddExamServlet</servlet-name>
        <url-pattern>/AdminAddExamServlet</url-pattern>
    </servlet-mapping>

    <!-- Admin Login Servlet -->
    <servlet>
        <servlet-name>AdminLoginServlet</servlet-name>
        <servlet-class>servlets.AdminLoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AdminLoginServlet</servlet-name>
        <url-pattern>/AdminLoginServlet</url-pattern>
    </servlet-mapping>

    <!-- Logout Servlet -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>servlets.LogoutServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServletStudent</servlet-name>
        <servlet-class>servlets.LogoutServletStudent</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LogoutServletStudent</servlet-name>
        <url-pattern>/LogoutServletStudent</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UpdateProfileServlet</servlet-name>
        <servlet-class>servlets.UpdateProfileServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>UpdateProfileServlet</servlet-name>
        <url-pattern>/UpdateProfileServlet</url-pattern>
    </servlet-mapping>

    <servlet>
    <servlet-name>ExportStudentsCSVServlet</servlet-name>
    <servlet-class>servlets.ExportStudentsCSVServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>ExportStudentsCSVServlet</servlet-name>
    <url-pattern>/ExportStudentsCSVServlet</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>CancelExamServlet</servlet-name>
    <servlet-class>servlets.CancelExamServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>CancelExamServlet</servlet-name>
    <url-pattern>/CancelExamServlet</url-pattern>
</servlet-mapping>

    <servlet>
        <servlet-name>AvailableExamsServlet</servlet-name>
        <servlet-class>servlets.AvailableExamsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AvailableExamsServlet</servlet-name>
        <url-pattern>/AvailableExamsServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UpcomingExamsServlet</servlet-name>
        <servlet-class>servlets.UpcomingExamsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpcomingExamsServlet</servlet-name>
        <url-pattern>/UpcomingExamsServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CompletedExamsServlet</servlet-name>
        <servlet-class>servlets.CompletedExamsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CompletedExamsServlet</servlet-name>
        <url-pattern>/CompletedExamsServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UserProfileServlet</servlet-name>
        <servlet-class>servlets.UserProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserProfileServlet</servlet-name>
        <url-pattern>/UserProfileServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UserStatsServlet</servlet-name>
        <servlet-class>servlets.UserStatsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserStatsServlet</servlet-name>
        <url-pattern>/UserStatsServlet</url-pattern>
    </servlet-mapping>

</web-app>
